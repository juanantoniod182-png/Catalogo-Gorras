<script>
(function () {
  'use strict';

  // ============================================================
  //  SPLASH → MAIN CONTENT
  // ============================================================
  function initSplash() {
    var splash      = document.getElementById('splash');
    var splashLogo  = document.getElementById('splashLogo');
    var mainContent = document.getElementById('mainContent');
    if (!splash || !mainContent) return;

    var dismissed = false;
    function dismissSplash() {
      if (dismissed) return;
      dismissed = true;

      splash.classList.add('is-hiding');

      setTimeout(function () {
        splash.classList.add('is-gone');
        document.body.classList.remove('splash-active');

        mainContent.style.display = 'block';
        mainContent.style.opacity = '0';
        mainContent.style.transform = 'translateY(20px)';
        mainContent.style.transition = 'opacity 0.8s ease, transform 0.8s ease';

        // force reflow then animate in
        void mainContent.offsetHeight;
        requestAnimationFrame(function () {
          mainContent.style.opacity = '1';
          mainContent.style.transform = 'translateY(0)';
        });
      }, 800);
    }

    splash.addEventListener('click', dismissSplash);
    if (splashLogo) splashLogo.addEventListener('click', function (e) {
      e.stopPropagation();
      dismissSplash();
    });
    splash.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        dismissSplash();
      }
    });
  }

  // ============================================================
  //  CATÁLOGO DINÁMICO — 57 productos desde gN_1.webp
  // ============================================================
  var TOTAL_PRODUCTS = 57;
  var PRICE = 590;
  var products = [];
  for (var i = 1; i <= TOTAL_PRODUCTS; i++) {
    products.push({ id: i, name: 'Gorra Modelo ' + i, price: PRICE, img: 'g' + i + '_1.webp' });
  }

  function renderProducts() {
    var grid = document.getElementById('productsGrid');
    if (!grid) return;

    var frag = document.createDocumentFragment();
    products.forEach(function (p, idx) {
      var card = document.createElement('article');
      card.className = 'product-card';
      card.style.setProperty('--i', idx);

      card.innerHTML =
        '<div class="product-img-wrap single-slide" data-product="' + p.id + '" data-current="0" data-total="1">' +
          '<span class="product-num">Mod. ' + p.id + '</span>' +
          '<div class="carousel-track">' +
            '<div class="carousel-slide active">' +
              '<img src="' + p.img + '" alt="' + p.name + '" loading="lazy" ' +
                'onerror="this.onerror=null;this.src=\'logo.webp\';" />' +
            '</div>' +
          '</div>' +
          '<button class="carousel-arrow carousel-prev" type="button" aria-label="Imagen anterior">&#10094;</button>' +
          '<button class="carousel-arrow carousel-next" type="button" aria-label="Imagen siguiente">&#10095;</button>' +
          '<div class="carousel-dots"></div>' +
        '</div>' +
        '<div class="product-body">' +
          '<div class="product-name">' + p.name + '</div>' +
          '<div class="product-style">Premium · Edición Limitada</div>' +
          '<div class="product-footer">' +
            '<div class="product-price">$' + p.price + '<span> MXN</span></div>' +
            '<button class="add-btn" data-id="' + p.id + '">' +
              '+ Agregar' +
            '</button>' +
          '</div>' +
        '</div>';

      frag.appendChild(card);
    });
    grid.appendChild(frag);

    // Probe additional images per product (g{id}_2.webp ... g{id}_8.webp).
    products.forEach(function (p) { probeProductImages(p.id); });
  }

  // ============================================================
  //  CARRUSEL — probe + navegación
  // ============================================================
  var MAX_IMAGES_PER_PRODUCT = 8;

  function probeProductImages(pid) {
    var attempts = MAX_IMAGES_PER_PRODUCT - 1;
    var done = 0;
    var found = [];
    for (var j = 2; j <= MAX_IMAGES_PER_PRODUCT; j++) {
      (function (idx) {
        var probe = new Image();
        probe.onload  = function () { found.push(idx); if (++done === attempts) finalize(); };
        probe.onerror = function () { if (++done === attempts) finalize(); };
        probe.src = 'g' + pid + '_' + idx + '.webp';
      })(j);
    }
    function finalize() {
      if (found.length === 0) return;
      found.sort(function (a, b) { return a - b; });
      var wrap = document.querySelector('.product-img-wrap[data-product="' + pid + '"]');
      if (!wrap) return;
      var track = wrap.querySelector('.carousel-track');
      var dotsContainer = wrap.querySelector('.carousel-dots');
      found.forEach(function (idx) {
        var slide = document.createElement('div');
        slide.className = 'carousel-slide';
        slide.innerHTML = '<img src="g' + pid + '_' + idx + '.webp" alt="" loading="lazy" />';
        track.appendChild(slide);
      });
      var total = 1 + found.length;
      while (dotsContainer.firstChild) dotsContainer.removeChild(dotsContainer.firstChild);
      for (var k = 0; k < total; k++) {
        var dot = document.createElement('span');
        dot.className = 'carousel-dot' + (k === 0 ? ' active' : '');
        dot.setAttribute('data-idx', k);
        dotsContainer.appendChild(dot);
      }
      wrap.classList.remove('single-slide');
      wrap.setAttribute('data-current', '0');
      wrap.setAttribute('data-total', total);
    }
  }

  function moveCarousel(wrap, newIdx) {
    if (!wrap || wrap.classList.contains('single-slide')) return;
    var current = parseInt(wrap.getAttribute('data-current') || '0', 10);
    var total   = parseInt(wrap.getAttribute('data-total')   || '1', 10);
    if (total <= 1) return;
    newIdx = ((newIdx % total) + total) % total;
    if (newIdx === current) return;
    var slides = wrap.querySelectorAll('.carousel-slide');
    var dots   = wrap.querySelectorAll('.carousel-dot');
    if (slides[current]) slides[current].classList.remove('active');
    if (slides[newIdx])  slides[newIdx].classList.add('active');
    if (dots[current])   dots[current].classList.remove('active');
    if (dots[newIdx])    dots[newIdx].classList.add('active');
    wrap.setAttribute('data-current', newIdx);
  }

  // ============================================================
  //  CARRITO
  // ============================================================
  var cart = [];

  function findItem(id) {
    for (var i = 0; i < cart.length; i++) if (cart[i].id === id) return cart[i];
    return null;
  }

  function addToCart(id) {
    var p = products[id - 1];
    if (!p) return;
    var existing = findItem(id);
    if (existing) existing.qty++;
    else cart.push({ id: p.id, name: p.name, price: p.price, img: p.img, qty: 1 });
    renderCart();
    bumpBadge();
    showToast('Agregado: ' + p.name);
  }

  function changeQty(id, delta) {
    var item = findItem(id);
    if (!item) return;
    item.qty += delta;
    if (item.qty <= 0) cart = cart.filter(function (it) { return it.id !== id; });
    renderCart();
  }

  function removeItem(id) {
    cart = cart.filter(function (it) { return it.id !== id; });
    renderCart();
  }

  function totals() {
    var totalQty = 0, subtotal = 0;
    cart.forEach(function (it) { totalQty += it.qty; subtotal += it.qty * it.price; });
    var pairs   = Math.floor(totalQty / 2);
    var singles = totalQty % 2;
    var total   = pairs * 1000 + singles * PRICE;
    var savings = subtotal - total;
    return { totalQty: totalQty, subtotal: subtotal, total: total, savings: savings, pairs: pairs };
  }

  function renderCart() {
    var itemsEl   = document.getElementById('cartItems');
    var emptyEl   = document.getElementById('cartEmpty');
    var totalEl   = document.getElementById('cartTotal');
    var savingsEl = document.getElementById('cartSavings');
    var promoEl   = document.getElementById('cartPromoNotice');
    var checkout  = document.getElementById('checkoutBtn');
    var badge     = document.getElementById('cartBadge');
    if (!itemsEl) return;

    var t = totals();
    badge.textContent = t.totalQty;

    // clear
    while (itemsEl.firstChild) itemsEl.removeChild(itemsEl.firstChild);

    if (cart.length === 0) {
      itemsEl.appendChild(emptyEl);
      checkout.disabled = true;
    } else {
      checkout.disabled = false;
      cart.forEach(function (it) {
        var row = document.createElement('div');
        row.className = 'cart-item';
        row.innerHTML =
          '<div class="cart-item-img">' +
            '<img src="' + it.img + '" alt="" onerror="this.onerror=null;this.src=\'logo.webp\';" />' +
          '</div>' +
          '<div class="cart-item-info">' +
            '<div class="cart-item-name">' + it.name + '</div>' +
            '<div class="cart-item-price">$' + it.price + ' MXN</div>' +
            '<div class="cart-item-qty">' +
              '<button class="qty-btn" data-act="dec" data-id="' + it.id + '">&minus;</button>' +
              '<span class="qty-num">' + it.qty + '</span>' +
              '<button class="qty-btn" data-act="inc" data-id="' + it.id + '">+</button>' +
            '</div>' +
          '</div>' +
          '<button class="cart-item-remove" data-act="rm" data-id="' + it.id + '" aria-label="Quitar">&times;</button>';
        itemsEl.appendChild(row);
      });
    }

    totalEl.textContent = '$' + t.total.toLocaleString('es-MX');
    if (t.savings > 0) {
      savingsEl.textContent = 'Ahorro: $' + t.savings.toLocaleString('es-MX');
      promoEl.classList.add('show');
    } else {
      savingsEl.textContent = '';
      promoEl.classList.remove('show');
    }
  }

  function bumpBadge() {
    var badge = document.getElementById('cartBadge');
    if (!badge) return;
    badge.classList.remove('bump');
    void badge.offsetWidth;
    badge.classList.add('bump');
  }

  // ============================================================
  //  CHECKOUT — WhatsApp
  // ============================================================
  var WHATSAPP_NUMBER = '529381264237';

  function sendWhatsApp() {
    if (cart.length === 0) return;
    var t = totals();
    var lines = ['Hola, quiero comprar:'];
    cart.forEach(function (it) {
      lines.push('• ' + it.name + ' x' + it.qty);
    });
    var totalLine = 'Total: $' + t.total.toLocaleString('es-MX');
    if (t.savings > 0) totalLine += ' (promo aplicada)';
    lines.push(totalLine);
    var url = 'https://wa.me/' + WHATSAPP_NUMBER + '?text=' + encodeURIComponent(lines.join('\n'));
    window.open(url, '_blank', 'noopener');
  }

  // ============================================================
  //  TOAST
  // ============================================================
  var toastTimer;
  function showToast(msg) {
    var toast = document.getElementById('toast');
    var msgEl = document.getElementById('toastMsg');
    if (!toast || !msgEl) return;
    msgEl.textContent = msg;
    toast.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(function () { toast.classList.remove('show'); }, 2200);
  }

  // ============================================================
  //  EVENTOS — delegación + UI
  // ============================================================
  function initUI() {
    var grid       = document.getElementById('productsGrid');
    var cartBtn    = document.getElementById('cartBtn');
    var cartClose  = document.getElementById('cartClose');
    var cartOverlay= document.getElementById('cartOverlay');
    var cartDrawer = document.getElementById('cartDrawer');
    var cartItems  = document.getElementById('cartItems');
    var header     = document.getElementById('siteHeader');

    function openCart() {
      cartDrawer.classList.add('open');
      cartOverlay.classList.add('open');
    }
    function closeCart() {
      cartDrawer.classList.remove('open');
      cartOverlay.classList.remove('open');
    }

    if (grid) grid.addEventListener('click', function (e) {
      var arrowPrev = e.target.closest('.carousel-prev');
      var arrowNext = e.target.closest('.carousel-next');
      var dot       = e.target.closest('.carousel-dot');
      if (arrowPrev || arrowNext || dot) {
        e.preventDefault();
        e.stopPropagation();
        var wrap = (arrowPrev || arrowNext || dot).closest('.product-img-wrap');
        if (!wrap) return;
        var current = parseInt(wrap.getAttribute('data-current') || '0', 10);
        if (arrowPrev)      moveCarousel(wrap, current - 1);
        else if (arrowNext) moveCarousel(wrap, current + 1);
        else if (dot)       moveCarousel(wrap, parseInt(dot.getAttribute('data-idx'), 10));
        return;
      }
      var btn = e.target.closest('.add-btn');
      if (!btn) return;
      var id = parseInt(btn.getAttribute('data-id'), 10);
      addToCart(id);
      btn.classList.add('added');
      setTimeout(function () { btn.classList.remove('added'); }, 600);
    });

    if (cartItems) cartItems.addEventListener('click', function (e) {
      var btn = e.target.closest('[data-act]');
      if (!btn) return;
      var id = parseInt(btn.getAttribute('data-id'), 10);
      var act = btn.getAttribute('data-act');
      if (act === 'inc') changeQty(id, 1);
      else if (act === 'dec') changeQty(id, -1);
      else if (act === 'rm') removeItem(id);
    });

    var checkoutBtn = document.getElementById('checkoutBtn');
    if (checkoutBtn) checkoutBtn.addEventListener('click', sendWhatsApp);

    if (cartBtn)    cartBtn.addEventListener('click', openCart);
    if (cartClose)  cartClose.addEventListener('click', closeCart);
    if (cartOverlay)cartOverlay.addEventListener('click', closeCart);

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeCart();
    });

    // header scroll state
    window.addEventListener('scroll', function () {
      if (!header) return;
      if (window.scrollY > 40) header.classList.add('scrolled');
      else header.classList.remove('scrolled');
    }, { passive: true });

    // reveal on scroll
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (en) {
          if (en.isIntersecting) {
            en.target.classList.add('visible');
            io.unobserve(en.target);
          }
        });
      }, { threshold: 0.12 });
      document.querySelectorAll('.reveal').forEach(function (el) { io.observe(el); });
    } else {
      document.querySelectorAll('.reveal').forEach(function (el) { el.classList.add('visible'); });
    }
  }

  // ============================================================
  //  BOOT
  // ============================================================
  function boot() {
    initSplash();
    renderProducts();
    initUI();
    renderCart();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }
})();
</script>

</body>
</html>
